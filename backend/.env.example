PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-at-least-32-random-chars
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:8080
DB_PATH=./database/cbquiz.db
BCRYPT_ROUNDS=10
# Required on first migrate — creates admin 00000001 (password is NOT stored in code)
ADMIN_PASSWORD=change-me-before-migrate
